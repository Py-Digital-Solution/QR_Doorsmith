# ─────────────────────────────────────────────────────────────
# DoorSmith Khati Rewards — environment variables
# Copy to `.env.local` and fill in. Never commit real secrets.
# ─────────────────────────────────────────────────────────────

# --- Database (Phase 0) ---
# Self-hosted MongoDB on the Oracle Cloud VM, configured as a SINGLE-NODE
# replica set (replicaSet=rs0) so multi-document transactions work.
# Format: mongodb://USER:PASSWORD@HOST:PORT/DBNAME?replicaSet=rs0&tls=true
MONGODB_URI="mongodb://doorsmith:CHANGE_ME@your-oracle-vm-ip:27017/doorsmith?replicaSet=rs0&authSource=admin&tls=true"

# --- Auth (Phase 1) ---
# Generate with: npx auth secret   (or: openssl rand -base64 32)
AUTH_SECRET=""
# Full URL of the deployment — MUST include https:// (e.g. https://qr-doorsmith.vercel.app)
# Without the protocol, Auth.js throws "TypeError: Invalid URL" on every request.
AUTH_URL=""

# --- File storage / MinIO on the Oracle VM (Phase 2) ---
S3_ENDPOINT="https://your-oracle-vm-ip:9000"
S3_ACCESS_KEY=""
S3_SECRET_KEY=""
S3_BUCKET="doorsmith"
 
# --- WhatsApp Cloud API (Phase 8) ---
# Business number is provided by the Client (SOW 3.2/3.4).
WHATSAPP_TOKEN=""
WHATSAPP_PHONE_NUMBER_ID=""

# --- WhatsApp Baileys microservice (runs on Oracle VM) ---
# URL where whatsapp-service is running (e.g. http://localhost:3099 on VM,
# or http://your-oracle-vm-ip:3099 from Vercel).
WA_SERVICE_URL="http://localhost:3099"
# Shared secret — set the same value in whatsapp-service env as WA_SERVICE_SECRET
WA_SERVICE_SECRET="change-me-to-a-random-string"

# --- SMTP Email (welcome emails to new staff users) ---
# Example: Gmail SMTP (use an App Password, not your main password)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="your@gmail.com"
SMTP_PASS=""
SMTP_FROM="DoorSmith <your@gmail.com>"

# reCAPTCHA Enterprise site key (Firebase App Check)
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=""

# --- Firebase Phone Auth ---
# Client-side (safe to expose — these go to the browser)
NEXT_PUBLIC_FIREBASE_API_KEY=""
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=""        # e.g. your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=""
NEXT_PUBLIC_FIREBASE_APP_ID=""             # e.g. 1:281570462871:web:2a9dc62595f717e4ddedd2

# Server-side — Firebase Admin SDK (from Service Account JSON)
FIREBASE_ADMIN_PROJECT_ID=""
FIREBASE_ADMIN_CLIENT_EMAIL=""
FIREBASE_ADMIN_PRIVATE_KEY=""              # paste the full -----BEGIN PRIVATE KEY----- block

# Set to 1 to skip env validation during CI lint/build.
# SKIP_ENV_VALIDATION="1"
